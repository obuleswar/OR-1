
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /apps/{appId} {
      allow read: if true;
      allow write: if false; 
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Balance can only be increased by the system logic (simulated by allowing update if specific conditions met)
      // For this prototype, we allow the user to update their own profile
      allow update: if isSignedIn() && (request.auth.uid == userId || request.resource.data.balance == resource.data.balance + 45);
    }

    match /referrals/{referralId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.referrerUid == request.auth.uid || resource.data.referredUid == request.auth.uid);
    }

    match /downloadRecords/{recordId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
