
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global rule for prototype stability: Allow all authenticated users to read and write.
    // This ensures that the client-side game settlement engine and history center
    // can function correctly without permission errors.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Specific match blocks for documentation and future refinement
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /transactions/{transactionId} {
      allow read, create: if request.auth != null;
    }

    match /bets/{betId} {
      allow read, write: if request.auth != null;
    }

    match /referrals/{referralId} {
      allow read, create: if request.auth != null;
    }
  }
}
