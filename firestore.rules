rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profile
    match /users/{userId} {
      allow read, create, update: if request.auth != null
        && request.auth.uid == userId;
      allow delete: if false;
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    // Wallet (Legacy or specific path check)
    match /wallets/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;

      allow write: if false;
    }

    // Referrals
    match /referrals/{referralId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Bets and Game Results
    // These require broader access for the background Game Engine to update statuses and settle payouts
    match /bets/{betId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null; // Needed for GameEngine settlement
      allow delete: if false;
    }

    match /wingo_results/{period} { allow read, write: if request.auth != null; }
    match /k3_results/{period} { allow read, write: if request.auth != null; }
    match /dragon_tiger_results/{period} { allow read, write: if request.auth != null; }
    match /mines_games/{gameId} { allow read, write: if request.auth != null; }

    // Fallback global rule for prototype stability
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}