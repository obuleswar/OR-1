
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOTYPE STABILITY RULE:
     * Allow authenticated users to read and write to all collections.
     * 
     * This is required because the prototype uses client-side logic and 
     * background game settlement engines that need to update data for 
     * multiple users.
     *
     * Deployment ID: global_auth_permissive_final_v3_clean
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // System configuration remains read-only
    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
