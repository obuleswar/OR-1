rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * GLOBAL PERMISSIVE RULES FOR PROTOTYPING
     * 
     * To resolve persistent "Missing or insufficient permissions" errors, 
     * we are allowing all authenticated users to read and write to any collection.
     * This ensures that features like the Game Engine, Wallet, and History Center 
     * function without interruption for any logged-in user.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Specific matchers are superseded by the global rule above but kept for structure.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }
    
    match /bets/{betId} {
      allow read, write: if request.auth != null;
    }
  }
}