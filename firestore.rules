rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOTYPE STABILITY RULE
     * This rule allows any authenticated user to read and write to any document.
     * 
     * Why this is necessary for this app:
     * 1. The 'GameEngine' component runs on the client and settles bets for multiple users.
     * 2. Transaction listing in the History Center requires broad read access.
     * 3. Real-time game result listeners require global access to the results collections.
     * 
     * Deployment trigger: 2024-05-24T10:00:00Z
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicit definitions for indexing and documentation clarity
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }
    match /bets/{betId} {
      allow read, write: if request.auth != null;
    }
    match /referrals/{referralId} {
      allow read, write: if request.auth != null;
    }
    match /wingo_results/{id} {
      allow read, write: if request.auth != null;
    }
    match /k3_results/{id} {
      allow read, write: if request.auth != null;
    }
    match /dragon_tiger_results/{id} {
      allow read, write: if request.auth != null;
    }
    match /mines_games/{id} {
      allow read, write: if request.auth != null;
    }
  }
}