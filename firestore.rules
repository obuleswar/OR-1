
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Allow update for balance and game-related metadata (needed for server settlement and referrals)
      allow update: if true;
    }

    match /wingo_results/{period} {
      allow read: if true;
      allow write: if true;
    }

    match /k3_results/{period} {
      allow read: if true;
      allow write: if true;
    }

    match /dragon_tiger_results/{period} {
      allow read: if true;
      allow write: if true;
    }

    match /bets/{betId} {
      allow read: if isSignedIn();
      allow write: if true;
    }

    match /transactions/{txnId} {
      allow read: if isSignedIn();
      allow write: if true;
    }

    match /mines_games/{gameId} {
      allow read, write: if true;
    }
    
    match /referrals/{refId} {
      allow read, write: if true;
    }
  }
}
