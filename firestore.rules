rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOTYPE STABILITY RULE:
     * Allow authenticated users to read and write to all collections.
     * This is required because the prototype uses client-side logic and 
     * server actions (via client SDK) to handle multi-user game settlements,
     * referrals, and transaction logging.
     */
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // System configuration is read-only even for authenticated users
    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}