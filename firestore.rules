/**
 * FIRESTORE SECURITY RULES
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a dual-layered security model:
 * 1. Strict Ownership: Private user data (profiles and app interactions) is secured using a hierarchical 
 *    ownership model. Access is granted only if the authenticated user's UID matches the document path.
 * 2. Role-Based Access Control (RBAC): Publicly accessible metadata (apps and categories) is readable 
 *    by all authenticated users but restricted for modification to accounts with administrative privileges.
 *
 * DATA STRUCTURE:
 * - /apps/{appId}: Global catalog of applications.
 * - /categories/{categoryId}: Global catalog of app categories.
 * - /users/{userId}: Private user profile information.
 * - /users/{userId}/userAppInteractions/{interactionId}: Private record of user-app relationships.
 * - /roles_admin/{userId}: Internal role mapping for administrative permissions.
 *
 * KEY SECURITY DECISIONS:
 * - Denormalization for Authorization: User IDs are stored both in the path and within the documents 
 *   to ensure relational integrity and fast, non-recursive security checks.
 * - Administrative Escalation: Admin rights are verified by checking for the existence of a document 
 *   in the '/roles_admin' collection, following a Database Access Control (DBAC) pattern.
 * - List Security: Query access for interactions is strictly scoped to the authenticated user's 
 *   own subcollection to prevent cross-user data leakage.
 * - Relational Integrity: On document creation, the rules enforce that internal ID fields match 
 *   the document's path to prevent data misplacement.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /**
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if a user is an administrator by verifying their presence in the roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Combines ownership check with existence check for updates and deletes.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Publicly accessible collection of applications. Reads are open to users; writes are admin-only.
     * @path /apps/{appId}
     * @allow Authenticated user reading an app (get), Admin creating/updating an app (create/update).
     * @deny Non-admin user attempting to delete an app.
     * @principle Role-Based Access Control (RBAC) for system-wide metadata.
     */
    match /apps/{appId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.id == appId;
      allow update: if isAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Publicly accessible collection of app categories. Reads are open to users; writes are admin-only.
     * @path /categories/{categoryId}
     * @allow Authenticated user listing categories (list), Admin updating a category (update).
     * @deny Authenticated non-admin user attempting to create a category.
     * @principle Role-Based Access Control (RBAC) for organizational data.
     */
    match /categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && request.resource.data.id == categoryId;
      allow update: if isAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
    }

    /**
     * @description Private user profile data. Each user can only access and manage their own profile.
     * @path /users/{userId}
     * @allow User 'abc' reading document '/users/abc' (get).
     * @deny User 'abc' attempting to read document '/users/xyz' (get).
     * @principle Ownership-based security model for root-level user documents.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users should not be able to list/search all other users.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Records of specific app interactions (e.g., downloads) for a user.
       * @path /users/{userId}/userAppInteractions/{interactionId}
       * @allow User 'abc' listing their own app interactions (list).
       * @deny User 'abc' trying to create an interaction record under User 'xyz's path.
       * @principle Structural segregation and relational integrity via internal userId validation.
       */
      match /userAppInteractions/{interactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description System-level collection defining administrative roles. 
     * @path /roles_admin/{userId}
     * @allow Internal logic checks via exists().
     * @deny Any direct client-side read or write to the roles collection.
     * @principle Explicit denial of direct access to sensitive permission mappings.
     */
    match /roles_admin/{userId} {
      allow read, write: if false;
    }
  }
}