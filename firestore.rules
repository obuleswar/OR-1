rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global rule for prototype stability: 
    // Allow authenticated users to read and write to all app collections.
    // This ensures background game settlement and history listeners function correctly.
    
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }

    match /bets/{betId} {
      allow read, write: if request.auth != null;
    }

    match /referrals/{referralId} {
      allow read, write: if request.auth != null;
    }
    
    match /dragon_tiger_results/{resultId} {
      allow read, write: if request.auth != null;
    }
    
    match /wingo_results/{resultId} {
      allow read, write: if request.auth != null;
    }
    
    match /k3_results/{resultId} {
      allow read, write: if request.auth != null;
    }
    
    match /mines_games/{gameId} {
      allow read, write: if request.auth != null;
    }

    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}