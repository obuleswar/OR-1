rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * PROTOTYPE SECURITY RULES: GLOBAL ACCESS
     * 
     * We are allowing all authenticated users full read/write access to any path.
     * This resolves persistent permission errors in the History Center and allows 
     * the background Game Engine to update balances and process settlements.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}