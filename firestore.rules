
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Engine needs to read for referrals and update for balances.
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // Results: Publicly readable and writable (for the game engine settlement)
    match /wingo_results/{period} {
      allow read, write: if true;
    }

    match /k3_results/{period} {
      allow read, write: if true;
    }

    match /dragon_tiger_results/{period} {
      allow read, write: if true;
    }

    // Bets: Publicly readable (for engine to settle) and writable (to place bets)
    match /bets/{betId} {
      allow read, write: if true;
    }

    // Transactions: Publicly writable (to log wins/losses/deposits)
    match /transactions/{txnId} {
      allow read: if isSignedIn();
      allow write: if true;
    }

    // Mines games: Active and past game sessions
    match /mines_games/{gameId} {
      allow read, write: if true;
    }
    
    // Referrals: History of bonuses
    match /referrals/{refId} {
      allow read, write: if true;
    }
  }
}
