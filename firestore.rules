
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Note: In production, balance updates should only happen via Cloud Functions.
      // For this prototype, we allow the user to update their own profile for demo actions.
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /wingo_results/{period} {
      allow read: if true;
      allow write: if false; // Only system should write
    }

    match /bets/{betId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false; // System only
    }

    match /transactions/{txnId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
