rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profile
    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == userId;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && !('balance' in request.resource.data.diff(resource.data).changedKeys())
        && !('wallet' in request.resource.data.diff(resource.data).changedKeys())
        && !('commission' in request.resource.data.diff(resource.data).changedKeys());

      allow delete: if false;
    }

    // Referral record (user can submit only once)
    match /referrals/{referralId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending";

      allow update, delete: if false;
    }

    // Transactions history
    match /transactions/{transactionId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if false;
    }

    // Bets collection
    match /bets/{betId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;

      allow delete: if false;
    }

    // Admin only system updates
    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}