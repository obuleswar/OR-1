{
  "entities": {
    "App": {
      "title": "App",
      "type": "object",
      "description": "Represents an application metadata.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "iconUrl": { "type": "string" },
        "latestVersion": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "downloadCount": { "type": "number" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and wallet information.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "ownReferralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Record of a financial movement (bet, win, deposit, etc).",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "bet", "win", "bonus", "referral"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Bet": {
      "title": "Bet",
      "type": "object",
      "description": "A user's wager on a game round.",
      "properties": {
        "userId": { "type": "string" },
        "period": { "type": "string" },
        "gameType": { "type": "string" },
        "betType": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "payout": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "User profiles and wallet balances."
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "description": "Global log of all financial activities."
        }
      },
      {
        "path": "/bets/{betId}",
        "definition": {
          "entityName": "Bet",
          "description": "Individual wagers placed by users."
        }
      },
      {
        "path": "/wingo_results/{period}",
        "definition": {
          "description": "Historical results for Wingo game rounds."
        }
      },
      {
        "path": "/k3_results/{period}",
        "definition": {
          "description": "Historical results for K3 game rounds."
        }
      },
      {
        "path": "/dragon_tiger_results/{period}",
        "definition": {
          "description": "Historical results for Dragon Tiger game rounds."
        }
      }
    ]
  }
}