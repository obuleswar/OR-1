{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and wallet information.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "ownReferralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalEarning": { "type": "number" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Record of a financial movement (bet, win, deposit, etc).",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "bet", "win", "bonus", "referral"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Bet": {
      "title": "Bet",
      "type": "object",
      "description": "A user's wager on a game round.",
      "properties": {
        "userId": { "type": "string" },
        "period": { "type": "string" },
        "gameType": { "type": "string" },
        "betType": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "payout": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Referral": {
      "title": "Referral",
      "type": "object",
      "description": "Bonus tracking for successful invites.",
      "properties": {
        "referrerUid": { "type": "string" },
        "referredUid": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and wallet balances."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global log of all financial activities."
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "Individual wagers placed by users."
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Tracking of bonuses earned from invites."
    },
    "/wingo_results/{period}": {
      "description": "Historical results for Wingo game rounds."
    },
    "/k3_results/{period}": {
      "description": "Historical results for K3 game rounds."
    },
    "/dragon_tiger_results/{period}": {
      "description": "Historical results for Dragon Tiger game rounds."
    },
    "/mines_games/{gameId}": {
      "description": "Active and finished Mines game sessions."
    }
  }
}
