
{
  "entities": {
    "App": {
      "title": "App",
      "type": "object",
      "description": "Represents a mobile application available in the store.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "publisher": { "type": "string" },
        "iconUrl": { "type": "string", "format": "uri" },
        "shortDescription": { "type": "string" },
        "description": { "type": "string" },
        "currentVersionId": { "type": "string" },
        "categoryIds": { "type": "array", "items": { "type": "string" } },
        "downloadCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "publisher", "downloadCount"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User profile tracking balance and referral data.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number", "description": "Current balance in INR." },
        "totalEarning": { "type": "number", "default": 0 },
        "ownReferralCode": { "type": "string", "description": "The user's unique code to share." },
        "referredBy": { "type": "string", "description": "The code used by this user when signing up." }
      },
      "required": ["uid", "email", "balance", "ownReferralCode"]
    },
    "WingoResult": {
      "title": "WingoResult",
      "type": "object",
      "properties": {
        "period": { "type": "string" },
        "num": { "type": "number" },
        "bs": { "type": "string", "enum": ["Big", "Small"] },
        "color": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WingoBet": {
      "title": "WingoBet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "period": { "type": "string" },
        "betType": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "payout": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DragonTigerResult": {
      "title": "DragonTigerResult",
      "type": "object",
      "properties": {
        "period": { "type": "string" },
        "winner": { "type": "string", "enum": ["Dragon", "Tiger", "Tie"] },
        "dragonCard": { "type": "number" },
        "tigerCard": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "MinesGame": {
      "title": "MinesGame",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "betAmount": { "type": "number" },
        "bombCount": { "type": "number" },
        "revealedIndices": { "type": "array", "items": { "type": "number" } },
        "bombPositions": { "type": "array", "items": { "type": "number" }, "description": "Hidden from client until game ends" },
        "status": { "type": "string", "enum": ["active", "won", "lost"] },
        "payout": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "bet", "win", "referral"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile and balance info."
        }
      },
      {
        "path": "/wingo_results/{period}",
        "definition": {
          "entityName": "WingoResult",
          "schema": { "$ref": "#/backend/entities/WingoResult" },
          "description": "History of Wingo game results."
        }
      },
      {
        "path": "/dragon_tiger_results/{period}",
        "definition": {
          "entityName": "DragonTigerResult",
          "schema": { "$ref": "#/backend/entities/DragonTigerResult" },
          "description": "History of Dragon vs Tiger game results."
        }
      },
      {
        "path": "/mines_games/{gameId}",
        "definition": {
          "entityName": "MinesGame",
          "schema": { "$ref": "#/backend/entities/MinesGame" },
          "description": "Active and past Mines game sessions."
        }
      },
      {
        "path": "/bets/{betId}",
        "definition": {
          "entityName": "WingoBet",
          "schema": { "$ref": "#/backend/entities/WingoBet" },
          "description": "User bets on games."
        }
      },
      {
        "path": "/transactions/{txnId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "History of all financial movements."
        }
      }
    ]
  }
}
