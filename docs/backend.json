{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and wallet information.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "ownReferralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalEarning": { "type": "number" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Record of a financial movement.",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "bet", "win", "bonus", "referral"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Bet": {
      "title": "Bet",
      "type": "object",
      "description": "A user's wager on a game.",
      "properties": {
        "userId": { "type": "string" },
        "period": { "type": "string" },
        "gameType": { "type": "string" },
        "betType": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "payout": { "type": "number" }
      }
    },
    "Referral": {
      "title": "Referral",
      "type": "object",
      "description": "Referral tracking record.",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and wallet balances."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User financial history."
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "Individual wagers."
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Referral records."
    },
    "/system/{document=**}": {
      "description": "System level configurations."
    }
  }
}