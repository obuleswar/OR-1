
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "User account and wallet information.",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "ownReferralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "totalEarning": { "type": "number" },
        "lastDepositAt": { "type": "string", "format": "date-time" },
        "lastWithdrawAt": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Record of a financial movement.",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "bet", "win", "bonus", "referral"] },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Bet": {
      "title": "Bet",
      "type": "object",
      "description": "A user's wager on a game.",
      "properties": {
        "userId": { "type": "string" },
        "period": { "type": "string" },
        "gameType": { "type": "string" },
        "betType": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "won", "lost"] },
        "payout": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Referral": {
      "title": "Referral",
      "type": "object",
      "description": "Referral tracking record.",
      "properties": {
        "referrerUid": { "type": "string" },
        "referredUid": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "GameResult": {
      "title": "GameResult",
      "type": "object",
      "description": "Generic game round result.",
      "properties": {
        "period": { "type": "string" },
        "num": { "type": "number" },
        "bs": { "type": "string" },
        "color": { "type": "array", "items": { "type": "string" } },
        "dice": { "type": "array", "items": { "type": "number" } },
        "sum": { "type": "number" },
        "winner": { "type": "string" },
        "dragonCard": { "type": "number" },
        "tigerCard": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and wallet balances."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User financial history."
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "Individual wagers."
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Referral tracking records."
    },
    "/wingo_results/{period}": {
      "schema": "GameResult",
      "description": "History of Wingo game rounds."
    },
    "/k3_results/{period}": {
      "schema": "GameResult",
      "description": "History of K3 game rounds."
    },
    "/dragon_tiger_results/{period}": {
      "schema": "GameResult",
      "description": "History of Dragon Tiger game rounds."
    },
    "/mines_games/{gameId}": {
      "description": "Active and completed Mines game sessions."
    },
    "/system/{document=**}": {
      "description": "System level configurations."
    }
  }
}
